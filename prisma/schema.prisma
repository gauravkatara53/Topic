generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @map("_id")
  name               String?
  email              String?              @unique
  password           String?
  role               String               @default("STUDENT") // STUDENT, FACULTY, ADMIN
  branch             String?
  semester           Int?
  collegeIdVerified  Boolean              @default(false)
  bio                String?
  cgpa               Float?
  creditsEarned      Int?
  rollNumber         String?
  hostel             String?
  joinedAt           DateTime?            @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  files              File[]
  attendanceRecords  AttendanceRecord[]
  portalCredentials  PortalCredential?
  followedSheets          UserFollowedSheet[]
  followedPopularSheets   UserFollowedPopularSheet[]
  questionRevisions       UserQuestionRevision[]
  completedQuestions      UserCompletedQuestion[]
  starredQuestions        UserStarredQuestion[]
  highlightedQuestions    UserQuestionHighlight[]
  questionNotes           UserQuestionNote[]
  customSheets            UserCustomSheet[]
  portfolio               UserPortfolio?
}

model Announcement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  body      String
  category  String   // exam, event, holiday, general
  date      DateTime @default(now())
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  date        DateTime
  type        String   // exam, holiday, event, deadline
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model File {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  uploaderId  String?   
  uploader    User?    @relation(fields: [uploaderId], references: [id])
  branch      String
  semester    Int
  subject     String
  type        String   // Notes, PYQ, Assignment
  url         String
  downloads   Int      @default(0)
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AttendanceRecord {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   
  user       User     @relation(fields: [userId], references: [id])
  subject    String
  attended   Int
  total      Int
  percentage Float
  scrapedAt  DateTime @default(now())
}

model PortalCredential {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @unique 
  user              User     @relation(fields: [userId], references: [id])
  encryptedUsername String
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model DSASheet {
  id                       String  @id @default(auto()) @map("_id") @db.ObjectId
  questionId               Int?    @map("id")
  title                    String?
  url                      String?
  difficulty               String?
  acceptance               Float?
  frequency                Float?
  tags                     String?
  companies                String?
  companies_with_timeframe String?

  @@map("DSA_Sheet")
}

model DSASheetCompany {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  company String @unique
  count   Int

  @@map("DSA_SHEET_COMPANY")
}

model UserFollowedSheet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String   
  colorTheme String?  @default("default")
  createdAt  DateTime @default(now())
  
  @@unique([userId, companyId])
}

model UserFollowedPopularSheet {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  popularSheetId String
  createdAt      DateTime @default(now())
  
  @@unique([userId, popularSheetId])
}

model UserQuestionRevision {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId   String   
  companyId    String?  // Context of which sheet the user was inside when scheduling
  lastRevised  DateTime?
  nextRevision DateTime?
  status       String   @default("Pending") // E.g., Pending, Overdue, Completed - tracked for scheduler algorithms
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, questionId])
}

model UserCompletedQuestion {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String   
  companyId  String?  // Easily aggregatable metric for overview cards
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
}

model UserStarredQuestion {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String   
  companyId  String?  // Context of sheet where they clicked star
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
}

model UserQuestionHighlight {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String   
  companyId  String?  
  colorTheme String   @default("default")
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
}

model PopularSheet {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?

  questions PopularSheetQuestion[]

  @@map("sheets")
}

model PopularQuestion {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId  Json?    // Mixed types in DB (e.g. "287" vs 701747), using Json to prevent conversion errors
  name        String
  slug        String?
  platform    String?
  difficulty  String?
  problemUrl  String?
  topics      String[]

  sheets PopularSheetQuestion[]
  customSheetQuestions CustomSheetQuestion[]

  @@map("questions")
}

model PopularSheetQuestion {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  sheetId    String   @db.ObjectId
  questionId String   @db.ObjectId // This relates to PopularQuestion.id (_id)
  topic      String?
  subTopic   String?
  resource   String? @default("")

  sheet    PopularSheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  question PopularQuestion? @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("sheetquestions")
}

model UserQuestionNote {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String   
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, questionId])
}

model UserCustomSheet {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  colorTheme  String?  @default("default")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  questions   CustomSheetQuestion[]
}

model CustomSheetQuestion {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  sheetId    String   @db.ObjectId
  questionId String   @db.ObjectId
  topic      String?
  subTopic   String?
  
  sheet    UserCustomSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  question PopularQuestion? @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("customsheetquestions")
}

model UserPortfolio {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Basic Stats
  totalSolved     Int      @default(0)
  activeDays      Int      @default(0)
  globalRank      Int?
  
  // Platform Handles
  github          String?
  leetcode        String?
  codeforces      String?
  codechef        String?
  geeksforgeeks   String?
  hackerrank      String?
  interviewbit    String?
  atcoder         String?
  codestudio      String?

  // Cached Aggregated Stats (JSON)
  statsCache      Json?    // For charts, topic analysis, etc.
  
  lastRefreshed   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
